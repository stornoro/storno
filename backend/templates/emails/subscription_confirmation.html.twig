{% extends 'emails/notification_base.html.twig' %}

{% block accent_gradient %}background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);{% endblock %}

{% block icon_emoji %}
    <div style="display: inline-block; width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); text-align: center; line-height: 64px; font-size: 30px; box-shadow: 0 4px 12px rgba(99,102,241,0.15);">
        &#127881;
    </div>
{% endblock %}

{% block heading %}{{ 'subscription.heading'|trans({}, 'emails', locale) }}{% endblock %}

{% block content %}
    <p style="margin: 0 0 20px 0; font-size: 15px; color: #374151; line-height: 1.6;">
        {{ 'subscription.greeting'|trans({'%firstName%': firstName}, 'emails', locale) }}
    </p>

    <p style="margin: 0 0 20px 0; font-size: 15px; color: #374151; line-height: 1.6;">
        {{ 'subscription.intro'|trans({'%planLabel%': planLabel}, 'emails', locale) }}
    </p>

    <!-- Plan details card -->
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; margin-bottom: 20px;">
        <tr style="background-color: #f9fafb;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280; border-bottom: 1px solid #f3f4f6;">{{ 'subscription.label_plan'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;">{{ planLabel }}</td>
        </tr>
        <tr style="background-color: #ffffff;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280; border-bottom: 1px solid #f3f4f6;">{{ 'subscription.label_amount'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;">{{ amount }} {{ currency }}</td>
        </tr>
        <tr style="background-color: #f9fafb;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280;">{{ 'subscription.label_interval'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right;">{{ intervalLabel }}</td>
        </tr>
    </table>

    {% if licenseKey %}
    <!-- License key card -->
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #eef2ff; border: 1px solid #c7d2fe; border-radius: 10px; margin-bottom: 20px;">
        <tr>
            <td style="padding: 18px 20px;">
                <p style="margin: 0 0 8px 0; font-size: 13px; font-weight: 600; color: #4338ca; text-transform: uppercase; letter-spacing: 0.5px;">{{ 'subscription.license_key_label'|trans({}, 'emails', locale) }}</p>
                <p style="margin: 0; font-size: 14px; color: #312e81; font-family: 'SF Mono', 'Fira Code', Consolas, monospace; word-break: break-all; background: #ffffff; padding: 10px 14px; border-radius: 6px; border: 1px solid #c7d2fe;">{{ licenseKey }}</p>
            </td>
        </tr>
    </table>
    {% endif %}

    <p style="margin: 0; font-size: 14px; color: #6b7280; line-height: 1.6;">
        {{ 'subscription.invoice_note'|trans({}, 'emails', locale) }}
    </p>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding: 0 36px 32px 36px;" align="center">
            <a href="{{ frontendUrl }}/settings/billing" target="_blank"
               style="display: inline-block; background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 14px 40px; border-radius: 8px; box-shadow: 0 2px 8px rgba(79,70,229,0.3);">
                {{ 'subscription.cta'|trans({}, 'emails', locale) }}
            </a>
        </td>
    </tr>
{% endblock %}
