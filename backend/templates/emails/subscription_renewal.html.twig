{% extends 'emails/notification_base.html.twig' %}

{% block accent_gradient %}background: linear-gradient(90deg, #22c55e 0%, #4ade80 50%, #86efac 100%);{% endblock %}

{% block icon_emoji %}
    <div style="display: inline-block; width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); text-align: center; line-height: 64px; font-size: 30px; box-shadow: 0 4px 12px rgba(34,197,94,0.15);">
        &#9989;
    </div>
{% endblock %}

{% block heading %}{{ 'renewal.heading'|trans({}, 'emails', locale) }}{% endblock %}

{% block content %}
    <p style="margin: 0 0 20px 0; font-size: 15px; color: #374151; line-height: 1.6;">
        {{ 'renewal.greeting'|trans({'%firstName%': firstName}, 'emails', locale) }}
    </p>

    <p style="margin: 0 0 20px 0; font-size: 15px; color: #374151; line-height: 1.6;">
        {{ 'renewal.intro'|trans({'%planLabel%': planLabel}, 'emails', locale) }}
    </p>

    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; margin-bottom: 20px;">
        <tr style="background-color: #f9fafb;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280; border-bottom: 1px solid #f3f4f6;">{{ 'renewal.label_plan'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;">{{ planLabel }}</td>
        </tr>
        <tr style="background-color: #ffffff;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280; border-bottom: 1px solid #f3f4f6;">{{ 'renewal.label_amount'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right; border-bottom: 1px solid #f3f4f6;">{{ amount }} {{ currency }}</td>
        </tr>
        <tr style="background-color: #f9fafb;">
            <td style="padding: 13px 20px; font-size: 14px; color: #6b7280;">{{ 'renewal.label_interval'|trans({}, 'emails', locale) }}</td>
            <td style="padding: 13px 20px; font-size: 14px; color: #111827; font-weight: 600; text-align: right;">{{ intervalLabel }}</td>
        </tr>
    </table>

    <p style="margin: 0; font-size: 14px; color: #6b7280; line-height: 1.6;">
        {{ 'renewal.invoice_note'|trans({}, 'emails', locale) }}
    </p>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding: 0 36px 32px 36px;" align="center">
            <a href="{{ frontendUrl }}/settings/billing" target="_blank"
               style="display: inline-block; background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 14px 40px; border-radius: 8px; box-shadow: 0 2px 8px rgba(22,163,74,0.3);">
                {{ 'renewal.cta'|trans({}, 'emails', locale) }}
            </a>
        </td>
    </tr>
{% endblock %}
