<div class="parties" style="overflow: hidden; margin-bottom: 25px;">
    <div class="party" style="float: left; width: 48%;">
        <div class="party-label">{{ supplierLabel|default(pdf_label('supplier', labelOverrides|default(null), locale|default('ro'), 'supplier')) }}</div>
        <div class="party-name">{{ company.name }}</div>
        {% if pdf_visible('supplier_cui', labelOverrides|default(null)) %}
            <div class="party-detail">{{ pdf_label('supplier_cui', labelOverrides|default(null), locale|default('ro'), 'cui') }}: {% if company.vatPayer is defined and company.vatPayer and company.cif matches '/^\\d+$/' %}RO{% endif %}{{ company.cif }}</div>
        {% endif %}
        {% if company.registrationNumber %}
            {% if pdf_visible('supplier_reg_number', labelOverrides|default(null)) %}
                <div class="party-detail">{{ pdf_label('supplier_reg_number', labelOverrides|default(null), locale|default('ro'), 'reg_number') }}: {{ company.registrationNumber }}</div>
            {% endif %}
        {% endif %}
        {% if pdf_visible('supplier_address', labelOverrides|default(null)) %}
            <div class="party-detail">{{ company.address }}</div>
            <div class="party-detail">{{ company.city }}{% if pdf_visible('supplier_county', labelOverrides|default(null)) and company.state %}, {{ company.state|county_name(locale|default('ro')) }}{% endif %}{% if pdf_visible('supplier_country', labelOverrides|default(null)) and company.country is defined and company.country and (client is not defined or client is null or client.country is not defined or company.country != client.country) %}, {{ company.country|country_name(locale|default('ro')) }}{% endif %}</div>
        {% endif %}
        {% if company.phone %}
            {% if pdf_visible('supplier_phone', labelOverrides|default(null)) %}
                <div class="party-detail">{{ pdf_label('supplier_phone', labelOverrides|default(null), locale|default('ro'), 'phone') }}: {{ company.phone }}</div>
            {% endif %}
        {% endif %}
        {% if company.email %}
            {% if pdf_visible('supplier_email', labelOverrides|default(null)) %}
                <div class="party-detail">{{ pdf_label('supplier_email', labelOverrides|default(null), locale|default('ro'), 'email') }}: {{ company.email }}</div>
            {% endif %}
        {% endif %}
        {% if company.website %}
            {% if pdf_visible('supplier_website', labelOverrides|default(null)) %}
                <div class="party-detail">{{ pdf_label('supplier_website', labelOverrides|default(null), locale|default('ro'), 'website') }}: {{ company.website }}</div>
            {% endif %}
        {% endif %}
        {% if (showBankInfo is not defined or showBankInfo) and (bankDisplaySection|default('both') == 'supplier' or bankDisplaySection|default('both') == 'both') %}
            {% if invoiceBankAccounts|default([])|length > 0 %}
                {% for account in invoiceBankAccounts %}
                    <div class="party-detail">
                        {% if bankDisplayMode|default('stacked') == 'inline' %}
                            {{ account.iban }}{% if account.bankName %} - {{ account.bankName }}{% endif %}
                        {% else %}
                            {% if account.bankName %}{{ account.bankName }}: {% endif %}{{ account.iban }}
                        {% endif %}
                    </div>
                {% endfor %}
            {% elseif company.bankAccount %}
                <div class="party-detail">{{ company.bankAccount }}{% if company.bankName %} - {{ company.bankName }}{% endif %}</div>
            {% endif %}
        {% endif %}
    </div>
    <div class="party" style="float: right; width: 48%;">
        <div class="party-label">{{ clientLabel|default(pdf_label('client', labelOverrides|default(null), locale|default('ro'), 'client')) }}</div>
        {# Use buyerSnapshot exclusively when available to preserve original buyer identity (e.g. for storno/credit notes).
           Only fall back to live client entity when no snapshot exists (old invoices). #}
        {% set bs = buyerSnapshot|default(null) %}
        {% set effectiveName = bs ? (bs.name|default('')) : (client ? client.name : '') %}
        {% set effectiveCui = bs ? (bs.cui|default(null)) : (client ? client.cui : null) %}
        {% set effectiveCnp = bs ? (bs.cnp|default(null)) : (client is not null and client.cnp is defined ? client.cnp : null) %}
        {% set effectiveType = bs ? (bs.type|default('company')) : (client is not null and client.type is defined ? client.type : 'company') %}
        {% set effectiveIsVatPayer = bs ? (bs.isVatPayer|default(false)) : (client is not null and client.isVatPayer is defined ? client.isVatPayer : false) %}
        {% set effectiveRegNumber = bs ? (bs.registrationNumber|default(null)) : (client is not null and client.registrationNumber is defined ? client.registrationNumber : null) %}
        {% set effectiveAddress = bs ? (bs.address|default('')) : (client ? client.address : '') %}
        {% set effectiveCity = bs ? (bs.city|default('')) : (client ? client.city : '') %}
        {% set effectiveCounty = bs ? (bs.county|default(null)) : (client is not null and client.county is defined ? client.county : null) %}
        {% set effectivePostalCode = bs ? (bs.postalCode|default(null)) : (client is not null and client.postalCode is defined ? client.postalCode : null) %}
        {% set effectiveCountry = bs ? (bs.country|default(null)) : (client is not null and client.country is defined ? client.country : null) %}
        {% set effectivePhone = bs ? (bs.phone|default(null)) : (client is not null and client.phone is defined ? client.phone : null) %}
        {% set effectiveEmail = bs ? (bs.email|default(null)) : (client is not null and client.email is defined ? client.email : null) %}
        {% if client or bs %}
            <div class="party-name">{{ effectiveName }}</div>
            {% if effectiveType == 'individual' %}
                {% if effectiveCnp %}
                    {% if pdf_visible('client_cnp', labelOverrides|default(null)) %}
                        <div class="party-detail">{{ pdf_label('client_cnp', labelOverrides|default(null), locale|default('ro'), 'cnp') }}: {{ effectiveCnp }}</div>
                    {% endif %}
                {% endif %}
            {% else %}
                {% if effectiveCui %}
                    {% if pdf_visible('client_cui', labelOverrides|default(null)) %}
                        <div class="party-detail">{{ pdf_label('client_cui', labelOverrides|default(null), locale|default('ro'), 'cui') }}: {% if effectiveIsVatPayer and effectiveCui matches '/^\\d+$/' %}RO{% endif %}{{ effectiveCui }}</div>
                    {% endif %}
                {% endif %}
                {% if effectiveRegNumber %}
                    {% if pdf_visible('client_reg_number', labelOverrides|default(null)) %}
                        <div class="party-detail">{{ pdf_label('client_reg_number', labelOverrides|default(null), locale|default('ro'), 'reg_number') }}: {{ effectiveRegNumber }}</div>
                    {% endif %}
                {% endif %}
            {% endif %}
            {% if pdf_visible('client_address', labelOverrides|default(null)) %}
                <div class="party-detail">{{ effectiveAddress }}</div>
                <div class="party-detail">{{ effectiveCity }}{% if pdf_visible('client_county', labelOverrides|default(null)) and effectiveCounty %}, {{ effectiveCounty|county_name(locale|default('ro')) }}{% endif %}{% if effectivePostalCode %}, {{ effectivePostalCode }}{% endif %}{% if pdf_visible('client_country', labelOverrides|default(null)) and effectiveCountry and (company is not defined or company.country is not defined or effectiveCountry != company.country) %}, {{ effectiveCountry|country_name(locale|default('ro')) }}{% endif %}</div>
            {% endif %}
            {% if effectivePhone %}
                {% if pdf_visible('client_phone', labelOverrides|default(null)) %}
                    <div class="party-detail">{{ pdf_label('client_phone', labelOverrides|default(null), locale|default('ro'), 'phone') }}: {{ effectivePhone }}</div>
                {% endif %}
            {% endif %}
            {% if effectiveEmail %}
                {% if pdf_visible('client_email', labelOverrides|default(null)) %}
                    <div class="party-detail">{{ pdf_label('client_email', labelOverrides|default(null), locale|default('ro'), 'email') }}: {{ effectiveEmail }}</div>
                {% endif %}
            {% endif %}
            {% if not bs and client is not null and client.contactPerson is defined and client.contactPerson %}
                {% if pdf_visible('client_contact', labelOverrides|default(null)) %}
                    <div class="party-detail">{{ pdf_label('client_contact', labelOverrides|default(null), locale|default('ro'), 'contact_person') }}: {{ client.contactPerson }}</div>
                {% endif %}
            {% endif %}
        {% endif %}
    </div>
</div>
