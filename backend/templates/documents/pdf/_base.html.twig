<!DOCTYPE html>
<html lang="{{ locale|default('ro') }}">
<head>
    <meta charset="UTF-8">
    <style>
        {% if fontsDir is defined and fontsDir %}
        @font-face {
            font-family: 'Noto Sans KR';
            font-style: normal;
            font-weight: 400;
            src: url('file://{{ fontsDir }}/NotoSansKR-Regular.otf') format('opentype');
        }
        @font-face {
            font-family: 'Noto Sans KR';
            font-style: normal;
            font-weight: 700;
            src: url('file://{{ fontsDir }}/NotoSansKR-Bold.otf') format('opentype');
        }
        {% endif %}
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: '{{ fontFamily|default('DejaVu Sans') }}', 'Noto Sans KR', Arial, sans-serif;
            font-size: 11px;
            color: #333;
            line-height: 1.5;
        }
        .page { padding: 30px 40px; }
        .text-right { text-align: right !important; }
        .text-center { text-align: center !important; }
        .negative { color: #dc2626; }
        .details-section { margin-top: 12px; font-size: 10px; color: #555; }
        .detail-row { margin-bottom: 2px; }
        .detail-label { color: #999; font-weight: 600; }
        .header-logo { margin-bottom: 8px; }
        .header-logo img { max-height: 50px; max-width: 160px; }
        .header-bar .header-logo { margin-bottom: 10px; }
        .header-bar .header-logo img { background: #fff; padding: 4px 8px; border-radius: 4px; }

        .cancelled-watermark {
            position: fixed;
            top: 45%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-25deg);
            font-size: 140px;
            font-weight: bold;
            color: rgba(220, 38, 38, 0.18);
            border: 10px solid rgba(220, 38, 38, 0.18);
            padding: 20px 60px;
            letter-spacing: 8px;
            z-index: 1000;
            pointer-events: none;
            white-space: nowrap;
        }

        {% block styles %}{% endblock %}

        {% if customCss %}
        {{ customCss|raw }}
        {% endif %}
    </style>
</head>
<body>
    {% if invoice is defined and invoice.status is defined and invoice.status.value == 'cancelled' %}
        <div class="cancelled-watermark">{{ 'cancelled_watermark'|trans({}, 'pdf', locale|default('ro')) }}</div>
    {% endif %}
    <div class="page">
        {% block content %}{% endblock %}
    </div>
</body>
</html>
